# Copy this file to .env and replace the placeholder values with your own production credentials.
# Do not commit .env to git. This file is safe to share.

PORT=5000
CLIENT_URL=https://your-frontend-domain.com

# Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Paystack settings
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# GetUs / fulfillment API settings
GETUS_API_KEY=your-getus-api-key
MYZTADATA_API_KEY=your-myztadata-api-key

# Admin credentials for backend scripts (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourAdminPassword123

# Set to false in production
USE_MOCK_PAYSTACK=false
